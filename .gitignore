# .gitignore — DLNM Cerebrovascular RJ Research Compendium
# =============================================================================

# R session files
.Rhistory
.RData
.Ruserdata
.Rproj.user/
*.Rproj
*.tmp

# renv library (keep lockfile)
renv/library/
renv/local/
renv/cellar/
renv/lock/
renv/sandbox/
renv/staging/

# Raw/interim/processed — allow pipeline fallback files
data/raw/*
data/interim/*
data/processed/*
!data/raw/.gitkeep
!data/raw/sih/
!data/raw/sim/
!data/raw/inmet/
!data/raw/inmet_zip/
!data/raw/pm25/
!data/raw/sih/*.rds
!data/raw/sim/*.rds
!data/raw/inmet/*.rds
!data/raw/inmet_zip/*.zip
!data/raw/pm25/*.json
!data/raw/*.csv
!data/interim/.gitkeep
!data/processed/.gitkeep
!data/processed/**/*.rds
!data/processed/**/*.csv
data/external/*
!data/external/.gitkeep

# Binary files — allow in data/ only
*.rds
*.RDS
*.RData
*.rda
*.zip
*.dbc
*.dbf
*.parquet
*.qs
!data/**/*.rds
!data/**/*.RDS
!data/**/*.zip
!data/**/*.csv
!data/**/*.json

# Download caches
cache/
tmp/
temp/
*_cache/

# R Markdown and LaTeX intermediates
*.aux
*.out
*.toc
*.tex
*.knit.md

# BSB manuscript — excluded from public compendium
reports/manuscript/*
reports/presentations/*
!reports/manuscript/.gitkeep
!reports/presentations/.gitkeep

# Legacy directories (not in this repo)
01_DLNMs_RJ_cerebrovascular/
02_MP25_RJ_exposicao/
03_RELATORIO_BSB2026/
04_AUDITORIA/

# OS files
Thumbs.db
.DS_Store
*.swp
*.swo
*~

# Environment
.env
.env.local

# Docker
docker-compose.override.yml

# IDE
.vscode/
.idea/
