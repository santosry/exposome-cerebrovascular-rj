# .gitignore — DLNM Cerebrovascular RJ Research Compendium
# =============================================================================

# R session files
.Rhistory
.RData
.Ruserdata
.Rproj.user/
*.Rproj
*.RData
*.rda
*.tmp

# renv library (but keep lockfile)
renv/library/
renv/local/
renv/cellar/
renv/lock/
renv/sandbox/
renv/staging/

# Raw data and intermediate files (regenerated by pipeline)
data/raw/*
data/interim/*
data/processed/*
!data/raw/.gitkeep
!data/interim/.gitkeep
!data/processed/.gitkeep
data/external/*
!data/external/.gitkeep

# Large model objects (> 50 MB)
*.rds
!data/README.md

# Download caches
cache/
tmp/
temp/
*_cache/

# R Markdown and LaTeX intermediates
*.aux
*.log
*.out
*.toc
*.tex
*.knit.md
*_files/
!**/.gitkeep

# Output directories (regenerated)
outputs/figures/*
outputs/tables/*
outputs/logs/*
outputs/audits/*
outputs/reports/*
!outputs/**/.gitkeep
reports/manuscript/*
reports/presentations/*
!reports/manuscript/.gitkeep
!reports/presentations/.gitkeep

# Logs
logs/*.log
!logs/.gitkeep

# Audit (except FAIR metadata)
audit/*.csv
audit/*.log
!audit/.gitkeep

# Legacy directories (kept for reference, not versioned)
01_DLNMs_RJ_cerebrovascular/data_raw/
01_DLNMs_RJ_cerebrovascular/data_interim/
01_DLNMs_RJ_cerebrovascular/data_processed/
01_DLNMs_RJ_cerebrovascular/outputs/
02_RELATORIO_BSB2026/*_files/
03_AUDITORIA/logs/
03_AUDITORIA/benchmark/
03_AUDITORIA/arquivos_centralizados/
04_publicacao_github/data_raw/
04_publicacao_github/data_interim/
04_publicacao_github/data_processed/
04_publicacao_github/outputs/
04_publicacao_github/figures/
04_publicacao_github/results/

# OS files
Thumbs.db
.DS_Store
*.swp
*.swo
*~

# Environment
.env
.env.local

# Docker
docker-compose.override.yml

# IDE
.vscode/
.idea/
