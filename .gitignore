# .gitignore - DLNM Cerebrovascular RJ Research Compendium
# =============================================================================

# R session files
.Rhistory
.RData
.Ruserdata
.Rproj.user/
*.Rproj
*.RData
*.rda
*.tmp

# renv library (but keep lockfile)
renv/library/
renv/local/
renv/cellar/
renv/lock/
renv/sandbox/
renv/staging/

# Raw fallback files for pipeline reproducibility (downloaded once, versioned as backup)
# If public APIs fail, these local files serve as alternative data source.
data/raw/*
data/interim/*
data/processed/*
!data/raw/.gitkeep
!data/raw/sih/
!data/raw/sim/
!data/raw/inmet/
!data/raw/pm25/
!data/raw/sih/*.rds
!data/raw/sim/*.rds
!data/raw/inmet/*.rds
!data/raw/pm25/*.json
!data/raw/*.csv
!data/interim/.gitkeep
!data/processed/.gitkeep
!data/processed/pm25/
!data/processed/pm25/*.csv
data/external/*
!data/external/.gitkeep

# Large binary/model objects are regenerated locally, not versioned
*.rds
*.RDS
*.RData
*.rda
*.zip
*.dbc
*.dbf
*.parquet
*.qs
# Download caches
cache/
tmp/
temp/
*_cache/

# R Markdown and LaTeX intermediates
*.aux
*.log
*.out
*.toc
*.tex
*.knit.md
*_files/
!**/.gitkeep

# Output directories (regenerated)
outputs/figures/*
outputs/tables/*
outputs/logs/*
outputs/audits/*
outputs/reports/*
!outputs/**/.gitkeep
reports/manuscript/*
reports/presentations/*
!reports/manuscript/.gitkeep
!reports/presentations/.gitkeep

# Logs
logs/*.log
!logs/.gitkeep

# Audit (except FAIR metadata)
audit/*.csv
audit/*.log
!audit/.gitkeep

# Legacy directories (kept for reference, not versioned)
01_DLNMs_RJ_cerebrovascular/data_raw/
01_DLNMs_RJ_cerebrovascular/data_interim/
01_DLNMs_RJ_cerebrovascular/data_processed/
01_DLNMs_RJ_cerebrovascular/outputs/
02_MP25_RJ_exposicao/data_raw/
02_MP25_RJ_exposicao/data_processed/
03_RELATORIO_BSB2026/*_files/
04_AUDITORIA/logs/
04_AUDITORIA/benchmark/
04_AUDITORIA/arquivos_centralizados/

# OS files
Thumbs.db
.DS_Store
*.swp
*.swo
*~

# Environment
.env
.env.local

# Docker
docker-compose.override.yml

# IDE
.vscode/
.idea/
